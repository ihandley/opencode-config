{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "slkiser/opencode-quota",
    "@tarquinen/opencode-smart-title"
  ],
  "agent": {
    "build": {
      "description": "Default primary agent with full tool access for implementation",
      "model": "opencode/minimax-m2.5-free"
    },
    "plan": {
      "description": "Read-only planning agent for analysis and design",
      "model": "opencode/minimax-m2.5-free",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow"
  },
  "snapshot": true,
  "autoupdate": true,
  "instructions": [
    "AGENTS.md",
    "instructions/mcp-preference.md",
    "instructions/skill-execution-rules.md",
    "instructions/job-coach-rules.md",
    "instructions/job-coach-persona.md"
  ],
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "google-workspace": {
      "type": "local",
      "enabled": true,
      "command": [
        "uvx",
        "workspace-mcp"
      ],
      "environment": {
        "GOOGLE_OAUTH_CLIENT_ID": "{env:GOOGLE_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "{env:GOOGLE_CLIENT_SECRET}"
      }
    }
  }
}