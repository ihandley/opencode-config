{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "plugin": ["slkiser/opencode-quota"],
  "agent": {
    "build": {
      "description": "Default primary agent with full tool access for implementation",
      "model": "opencode/minimax-m2.5-free"
    },
    "plan": {
      "description": "Read-only planning agent for analysis and design",
      "model": "opencode/minimax-m2.5-free",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow"
  },
  "snapshot": true,
  "autoupdate": true,
  "instructions": [".opencode/instructions/mcp-preference.md"],
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
    // To enable gmail MCP: source .env before running opencode, or add to .zshrc
    // "gmail": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@mcp-z/mcp-gmail"],
    //   "environment": {
    //     "GOOGLE_CLIENT_ID": "{env:GOOGLE_CLIENT_ID}",
    //     "GOOGLE_CLIENT_SECRET": "{env:GOOGLE_CLIENT_SECRET}"
    //   }
    // }
  }
}